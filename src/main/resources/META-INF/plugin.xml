<idea-plugin>
    <id>com.ghostdebugger</id>
    <name>Aegis Debug</name>
    <version>0.1.0</version>
    <vendor email="team@ghostdebugger.dev">Aegis Debug</vendor>

    <description><![CDATA[
    <h2>Aegis Debug — privacy-first code debugging for IntelliJ</h2>
    <p>
        Static analysis first. Deterministic fixes where possible.
        Optional local or cloud AI for deeper reasoning — off by default.
    </p>
    <ul>
        <li><strong>NeuroMap</strong> — visual project graph with issue overlay</li>
        <li><strong>Static-first analysis</strong> — null safety, state init, async flow, cycles, complexity</li>
        <li><strong>Optional AI</strong> — Ollama (local) or OpenAI (cloud)</li>
        <li><strong>Trust signals</strong> — engine-verified vs AI-suggested, always clearly labeled</li>
        <li><strong>Privacy</strong> — local-first; cloud requires explicit opt-in</li>
    </ul>
]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Tool Window para el NeuroMap -->
        <toolWindow id="GhostDebugger"
                    secondary="true"
                    anchor="right"
                    factoryClass="com.ghostdebugger.toolwindow.GhostDebuggerToolWindowFactory"
                    icon="/icons/aegis.svg"/>

        <!-- Servicio principal del plugin (project-level) -->
        <projectService
                serviceImplementation="com.ghostdebugger.GhostDebuggerService"/>

        <!-- Application-level settings service -->
        <applicationService
                serviceImplementation="com.ghostdebugger.settings.GhostDebuggerSettings"/>

        <!-- Settings/Configurable para API key de OpenAI -->
        <applicationConfigurable
                instance="com.ghostdebugger.settings.GhostDebuggerConfigurable"
                id="com.ghostdebugger.settings"
                displayName="Aegis Debug"
                parentId="tools"/>

        <!-- ExternalAnnotator for Problems window — registered for all languages -->
        <externalAnnotator language=""
                           implementationClass="com.ghostdebugger.annotator.GhostDebuggerAnnotator"/>

        <!-- Notification group -->
        <notificationGroup id="GhostDebugger"
                           displayType="BALLOON"/>
    </extensions>

    <actions>
        <group id="GhostDebugger.Menu" text="Aegis Debug" popup="true"
               icon="/icons/aegis.svg">
            <add-to-group group-id="ToolsMenu" anchor="last"/>

            <action id="GhostDebugger.Analyze"
                    class="com.ghostdebugger.actions.AnalyzeProjectAction"
                    text="Analyze Project"
                    description="Analyze entire project with Aegis Debug"
                    icon="/icons/analyze.svg">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt G"/>
            </action>

            <action id="GhostDebugger.ExplainSystem"
                    class="com.ghostdebugger.actions.ExplainSystemAction"
                    text="Explain System"
                    description="Get AI-powered explanation of the project architecture"/>

            <action id="GhostDebugger.ConfigureApiKey"
                    class="com.ghostdebugger.actions.ConfigureApiKeyAction"
                    text="Configure OpenAI API Key"
                    description="Set up your OpenAI API key for AI features"/>
        </group>
    </actions>
</idea-plugin>
